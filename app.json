{
  "expo": {
    "name": "Beth Notes",
    "slug": "beth-notes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "raijin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Raijin to convert your speech to text.",
        "NSMicrophoneUsageDescription": "Allow Raijin to access your microphone for voice notes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAD6E7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.itachi.bethnotes",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAD6E7",
          "dark": {
            "backgroundColor": "#2A0F1B"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Raijin to access your microphone for voice notes.",
          "speechRecognitionPermission": "Allow Raijin to convert your speech to text."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e989fcc8-c739-4360-8c53-49522eef4854"
      }
    }
  }
}
